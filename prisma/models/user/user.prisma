// User model

model User {
    id           String  @id @default(uuid())
    firstName    String
    middleName   String?
    lastName     String
    countryCode  String
    mobile       String
    email        String  @unique
    passwordHash String

    personal     PersonalDetails?
    professional ProfessionalDetails?
    sports       SportsPreferences?
    address      Address?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([countryCode, mobile], name: "mobile_unique")
    @@map("users")
}
