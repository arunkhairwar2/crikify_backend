model Contact {
    id                   String  @id @default(uuid())
    user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId               String
    primaryPhoneNumber   String
    emergencyPhoneNumber String?
    email                String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("contacts")
}
